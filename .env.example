# Copy this file to .env and fill in the values before running the project.
# $ cp .env.example .env

# --- Security ---
# Used in: backend/settings.py → SECRET_KEY
SECRET_KEY=your-secret-key-here

# Used in: backend/settings.py → DEBUG
# Set to False in production
DEBUG=True

# Comma-separated list. Used in: backend/settings.py → ALLOWED_HOSTS
# Example: ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Used in: backend/settings.py → DATABASES
# SQLite (default for local dev):
DATABASE_URL=sqlite:///db.sqlite3
# Postgres (recommended for production):
# DATABASE_URL=postgres://user:password@localhost:5432/umes_db

# --- Localisation ---
# Used in: backend/settings.py → LANGUAGE_CODE
LANGUAGE_CODE=en-us

# Used in: backend/settings.py → TIME_ZONE
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIME_ZONE=UTC
